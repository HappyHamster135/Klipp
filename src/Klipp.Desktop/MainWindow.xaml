<Window
    x:Class="Klipp.Desktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Klipp.Desktop.Controls"
    xmlns:local="using:Klipp.Desktop"
    mc:Ignorable="d"
    Title="Klipp">

    <Grid Background="{StaticResource KlippBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Background="{StaticResource KlippTitleBarBrush}"
              Height="48"
              Padding="16,0,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Spacing="10">
                <Border Width="20"
                        Height="20"
                        Background="{StaticResource KlippAccentBrush}"
                        CornerRadius="5" />
                <TextBlock Text="Klipp"
                           Style="{StaticResource KlippBodyText}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">

                <!-- Lägesväljare -->
                <ComboBox x:Name="ModeSelector"
                          SelectionChanged="OnModeChanged"
                          MinWidth="120"
                          FontSize="12"
                          VerticalAlignment="Center">
                    <ComboBoxItem Content="Inspelning" IsSelected="True" />
                    <ComboBoxItem Content="Klipp-läge" />
                </ComboBox>

                <!-- Klipplängd — syns bara i Klipp-läge -->
                <ComboBox x:Name="ClipLengthSelector"
                          SelectionChanged="OnClipLengthChanged"
                          MinWidth="90"
                          FontSize="12"
                          VerticalAlignment="Center"
                          Visibility="Collapsed">
                    <ComboBoxItem Content="15s" />
                    <ComboBoxItem Content="30s" IsSelected="True" />
                    <ComboBoxItem Content="60s" />
                    <ComboBoxItem Content="2 min" />
                </ComboBox>

                <!-- Hotkey-fält: visar nuvarande hotkey, klicka för att ändra -->
                <Button x:Name="HotkeyButton"
                        Click="OnHotkeyButtonClicked"
                        Background="Transparent"
                        BorderBrush="{StaticResource KlippBorderBrush}"
                        BorderThickness="1"
                        Foreground="{StaticResource KlippTextSecondaryBrush}"
                        Padding="10,5,10,5"
                        CornerRadius="6"
                        FontSize="12"
                        VerticalAlignment="Center"
                        ToolTipService.ToolTip="Klicka och tryck en tangentkombination för att ändra spara-hotkey">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="&#x2328;" FontSize="13" VerticalAlignment="Center" />
                        <TextBlock x:Name="HotkeyText"
                                   Text="Ctrl + Shift + S"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Border x:Name="StatusPill"
                        Background="Transparent"
                        BorderBrush="{StaticResource KlippBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="10,4,12,4"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot"
                                 Width="8"
                                 Height="8"
                                 Fill="{StaticResource KlippTextMutedBrush}"
                                 VerticalAlignment="Center" />
                        <TextBlock x:Name="StatusText"
                                   Text="Inte aktiv"
                                   Style="{StaticResource KlippBodyTextSecondary}"
                                   Foreground="{StaticResource KlippTextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Button x:Name="SaveClipButton"
                        Click="OnSaveClipClicked"
                        Content="Spara klipp"
                        Background="Transparent"
                        Foreground="{StaticResource KlippTextSecondaryBrush}"
                        BorderBrush="{StaticResource KlippBorderBrush}"
                        BorderThickness="1"
                        Padding="12,5,12,5"
                        CornerRadius="6"
                        FontSize="12"
                        IsEnabled="False" />

                <Button x:Name="RecordButton"
                        Click="OnRecordClicked"
                        Content="Spela in"
                        Background="{StaticResource KlippAccentBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="14,5,14,5"
                        CornerRadius="6"
                        FontSize="12"
                        FontWeight="SemiBold" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">

            <Grid x:Name="LibraryView" Padding="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="Mina klipp"
                                   Style="{StaticResource KlippHeadingMedium}" />
                        <TextBlock x:Name="LibraryStatsText"
                                   Text="0 klipp"
                                   Style="{StaticResource KlippBodyTextSecondary}" />
                    </StackPanel>
                </Grid>

                <Border x:Name="EmptyState"
                        Grid.Row="1"
                        Background="{StaticResource KlippSurfaceBrush}"
                        BorderBrush="{StaticResource KlippBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource KlippRadiusMd}"
                        Padding="40"
                        Visibility="Visible">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="8">
                        <TextBlock Text="Inga klipp än"
                                   Style="{StaticResource KlippBodyText}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Klicka 'Spela in' för att börja"
                                   Style="{StaticResource KlippBodyTextSecondary}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <ScrollViewer x:Name="ClipsScroller"
                              Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="Collapsed">
                    <ItemsRepeater ItemsSource="{x:Bind LibraryService.Clips, Mode=OneTime}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="220"
                                               MinItemHeight="190"
                                               MinRowSpacing="14"
                                               MinColumnSpacing="14"
                                               ItemsStretch="Fill" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="local:ClipViewModel">
                                <controls:ClipCard ClipTitle="{x:Bind Title, Mode=OneWay}"
                                                   ClipMeta="{x:Bind Meta, Mode=OneWay}"
                                                   Duration="{x:Bind Duration, Mode=OneWay}"
                                                   IsNew="{x:Bind IsNew, Mode=OneWay}"
                                                   ClipFilePath="{x:Bind FilePath, Mode=OneWay}"
                                                   ThumbnailPath="{x:Bind ThumbnailPath, Mode=OneWay}"
                                                   Clicked="OnClipCardClicked" />
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </ScrollViewer>
            </Grid>

            <controls:ClipPlayerView x:Name="PlayerView"
                                     Visibility="Collapsed"
                                     BackRequested="OnPlayerBackRequested"
                                     DeleteRequested="OnPlayerDeleteRequested"
                                     PrevRequested="OnPlayerPrevRequested"
                                     NextRequested="OnPlayerNextRequested" />
        </Grid>
    </Grid>
</Window>
