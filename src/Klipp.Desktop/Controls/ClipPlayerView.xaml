<UserControl
    x:Class="Klipp.Desktop.Controls.ClipPlayerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:webview2="using:Microsoft.UI.Xaml.Controls">

    <Grid Background="{StaticResource KlippBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="24,16,24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Click="OnBackClicked"
                    Background="Transparent"
                    BorderBrush="{StaticResource KlippBorderBrush}"
                    BorderThickness="1"
                    Foreground="{StaticResource KlippTextSecondaryBrush}"
                    Padding="12,6,14,6"
                    CornerRadius="6"
                    FontSize="12">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="&#x2190;" FontSize="14" />
                    <TextBlock Text="Bibliotek" />
                </StackPanel>
            </Button>

            <TextBlock Grid.Column="1"
                       x:Name="TitleText"
                       Text="Klipp"
                       Style="{StaticResource KlippHeadingMedium}"
                       Margin="16,0,16,0"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">
                <Button Click="OnOpenFolderClicked"
                        Content="Visa i mapp"
                        Background="Transparent"
                        Foreground="{StaticResource KlippTextSecondaryBrush}"
                        BorderBrush="{StaticResource KlippBorderBrush}"
                        BorderThickness="1"
                        Padding="12,6,12,6"
                        CornerRadius="6"
                        FontSize="12" />
                <Button Click="OnDeleteClicked"
                        Content="Ta bort"
                        Background="Transparent"
                        Foreground="{StaticResource KlippDangerBrush}"
                        BorderBrush="{StaticResource KlippBorderBrush}"
                        BorderThickness="1"
                        Padding="12,6,12,6"
                        CornerRadius="6"
                        FontSize="12" />
            </StackPanel>
        </Grid>

        <!-- Spelar-yta med pilar som overlay -->
        <Grid Grid.Row="1" Margin="24,0,24,24">
            <Border CornerRadius="{StaticResource KlippRadiusMd}"
                    Background="Black">
                <webview2:WebView2 x:Name="PlayerWebView" />
            </Border>

            <!-- Vänster pil -->
            <Button x:Name="PrevButton"
                    Click="OnPrevClicked"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Margin="16,0,0,0"
                    Width="44"
                    Height="44"
                    Background="#A6000000"
                    BorderThickness="0"
                    CornerRadius="22"
                    Foreground="White"
                    FontSize="20"
                    FontWeight="SemiBold"
                    Padding="0">
                <TextBlock Text="&#x2039;"
                           FontSize="24"
                           Margin="0,-4,0,0" />
            </Button>

            <!-- Höger pil -->
            <Button x:Name="NextButton"
                    Click="OnNextClicked"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,16,0"
                    Width="44"
                    Height="44"
                    Background="#A6000000"
                    BorderThickness="0"
                    CornerRadius="22"
                    Foreground="White"
                    FontSize="20"
                    FontWeight="SemiBold"
                    Padding="0">
                <TextBlock Text="&#x203A;"
                           FontSize="24"
                           Margin="0,-4,0,0" />
            </Button>
        </Grid>
    </Grid>
</UserControl>
